# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=pipeimob_challenge

# Ou use DATABASE_URL diretamente:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/pipeimob_challenge

# JWT (defina sua secret key)
# JWT_SECRET_KEY=sua-chave-secreta-aqui
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend
# VITE_API_URL=/api/v1
